FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Set this to use Firebase Realtime Database for room storage instead of Firestore.
FIREBASE_DATABASE_URL=https://simple-fours-default-rtdb.firebaseio.com

# Optional explicit local override without Firebase. Do not use in production.
SIMPLEFOURS_STORE=memory
